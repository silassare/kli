{
	"name": "silassare/kli",
	"description": "Kli helps you add an interactive command-line interface to your php project.",
	"keywords": [
		"kli",
		"cli",
		"command",
		"command-line",
		"command-line-tool",
		"php-cli"
	],
	"require": {
		"php": ">=8.1",
		"ext-readline": "*",
		"ext-posix": "*",
		"ext-mbstring": "*"
	},
	"require-dev": {
		"oliup/oliup-cs-php": "dev-main",
		"roave/security-advisories": "dev-latest",
		"phpunit/phpunit": "^9.6.21",
		"vimeo/psalm": "^6.0"
	},
	"homepage": "https://github.com/silassare/kli#readme",
	"archive": {
		"exclude": [
			"/tests"
		]
	},
	"autoload": {
		"psr-4": {
			"Kli\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Kli\\Tests\\": "tests/"
		}
	},
	"authors": [
		{
			"name": "Emile Silas Sare",
			"homepage": "https://github.com/silassare"
		}
	],
	"license": "MIT",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"branch-alias": {
			"dev-main": "2.x-dev"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": false
		}
	}
}
